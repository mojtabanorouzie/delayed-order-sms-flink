{
  "scenarioName": "duplicate-events",
  "description": "[E2E] Duplicate events must not produce duplicate SMS.",
  "topic": "Orders",
  "topicType": "compacted",
  "keyField": "orderId",
  "defaultOrderCount": 100,
  "events": [
    {
      "step": 1,
      "delayAfterPreviousEventMs": 0,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "status": "CREATED",
        "expectedDeliveryTime": "now+5s",
        "createdAt": "now",
        "lastUpdatedAt": "now",
        "eventTime": "now",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 2,
      "delayAfterPreviousEventMs": 500,
      "messageKey": "{{orderId}}",
      "duplicateOfStep": 1
    },
    {
      "step": 3,
      "delayAfterPreviousEventMs": 500,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now+5s",
        "createdAt": "now",
        "lastUpdatedAt": "now+5s",
        "eventTime": "now+5s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+5s"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 4,
      "delayAfterPreviousEventMs": 500,
      "messageKey": "{{orderId}}",
      "duplicateOfStep": 3
    }
  ],
  "expectedResult": {
    "smsCommandExpected": true,
    "expectedSmsCommandCountPerOrder": 1,
    "description": "At most one SMS per order."
  }
}