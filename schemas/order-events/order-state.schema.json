
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/order-events/order-state.schema.json",
  "title": "Order State",
  "description": "Full latest order state published to the compacted Orders Kafka topic. Each message must be keyed by orderId.",
  "type": "object",
  "required": [
    "orderId",
    "customerId",
    "storeId",
    "status",
    "expectedDeliveryTime",
    "createdAt",
    "lastUpdatedAt",
    "eventTime",
    "stateLogs",
    "schemaVersion"
  ],
  "properties": {
    "orderId": {
      "type": "string",
      "minLength": 1,
      "description": "Unique order identifier. This value must also be used as the Kafka message key."
    },
    "customerId": {
      "type": "string",
      "minLength": 1,
      "description": "Customer identifier."
    },
    "storeId": {
      "type": "string",
      "minLength": 1,
      "description": "Store identifier."
    },
    "status": {
      "type": "string",
      "description": "Latest current status of the order.",
      "enum": [
        "CREATED",
        "ACCEPTED",
        "PICKED_UP",
        "DELIVERED",
        "CANCELLED"
      ]
    },
    "expectedDeliveryTime": {
      "type": "string",
      "format": "date-time",
      "description": "Current expected delivery deadline."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Order creation timestamp."
    },
    "lastUpdatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp of the latest order state update."
    },
    "eventTime": {
      "type": "string",
      "format": "date-time",
      "description": "Business event time of the latest update."
    },
    "stateLogs": {
      "type": "array",
      "description": "Historical state changes and important order updates.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "status",
          "at"
        ],
        "properties": {
          "status": {
            "type": "string",
            "description": "Historical status or update action.",
            "enum": [
              "CREATED",
              "ACCEPTED",
              "PICKED_UP",
              "DELIVERED",
              "CANCELLED",
              "ETA_UPDATED"
            ]
          },
          "at": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of this historical state change."
          }
        },
        "additionalProperties": true
      }
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Schema version."
    }
  },
  "additionalProperties": true
}