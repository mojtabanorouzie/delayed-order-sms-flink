{
  "scenarioName": "courier-overload",
  "description": "Ten orders assigned to the same courier. At the 8th active order the CourierOverloadJob emits a PAUSE command.",
  "topic": "Orders",
  "topicType": "compacted",
  "keyField": "orderId",
  "defaultOrderCount": 10,
  "events": [
    {
      "step": 1,
      "delayAfterPreviousEventMs": 100,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "courierId": "courier-overload-e2e",
        "status": "CREATED",
        "expectedDeliveryTime": "now+30m",
        "createdAt": "now",
        "lastUpdatedAt": "now",
        "eventTime": "now",
        "deliveryFee": 5.00,
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 2,
      "delayAfterPreviousEventMs": 100,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "courierId": "courier-overload-e2e",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now+30m",
        "createdAt": "now",
        "lastUpdatedAt": "now+5s",
        "eventTime": "now+5s",
        "deliveryFee": 5.00,
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+5s"
          }
        ],
        "schemaVersion": 1
      }
    }
  ],
  "expectedResult": {
    "courierPauseCommandExpected": true,
    "expectedAction": "PAUSE",
    "expectedCourierId": "courier-overload-e2e",
    "description": "One COURIER_PAUSE command for courier-overload-e2e when its 8th active order is registered."
  }
}
