{
  "scenarioName": "duplicate-events",
  "description": "Duplicate delayed events are published. Duplicate events must not produce duplicate SMS commands.",
  "topic": "Orders",
  "topicType": "compacted",
  "keyField": "orderId",
  "defaultOrderCount": 100,
  "events": [
    {
      "step": 1,
      "delayAfterPreviousEventMs": 0,
      "messageKey": "{{orderId}}",
      "etaOffset": "-30s",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "CREATED",
        "expectedDeliveryTime": "now",
        "createdAt": "now",
        "lastUpdatedAt": "now",
        "eventTime": "now",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 2,
      "delayAfterPreviousEventMs": 500,
      "messageKey": "{{orderId}}",
      "duplicateOfStep": 1
    },
    {
      "step": 3,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "etaOffset": "-30s",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now",
        "createdAt": "now",
        "lastUpdatedAt": "now+10s",
        "eventTime": "now+10s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 4,
      "delayAfterPreviousEventMs": 500,
      "messageKey": "{{orderId}}",
      "duplicateOfStep": 3
    }
  ],
  "expectedResult": {
    "smsCommandExpected": true,
    "expectedSmsCommandCountPerOrder": 1,
    "description": "At most one SEND_DELAY_SMS command should be emitted per order (idempotence)."
  }
}