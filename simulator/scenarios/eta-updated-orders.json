{
  "scenarioName": "eta-updated-orders",
  "description": "Orders receive updated expected delivery time. The Flink job should use the latest expectedDeliveryTime.",
  "topic": "Orders",
  "topicType": "compacted",
  "keyField": "orderId",
  "defaultOrderCount": 100,
  "events": [
    {
      "step": 1,
      "delayAfterPreviousEventMs": 0,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "CREATED",
        "expectedDeliveryTime": "now+60s",
        "createdAt": "now",
        "lastUpdatedAt": "now",
        "eventTime": "now",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 2,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now+60s",
        "createdAt": "now",
        "lastUpdatedAt": "now+10s",
        "eventTime": "now+10s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 3,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now+180s",
        "createdAt": "now",
        "lastUpdatedAt": "now+30s",
        "eventTime": "now+30s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          },
          {
            "status": "ETA_UPDATED",
            "at": "now+30s"
          }
        ],
        "schemaVersion": 1
      }
    }
  ],
  "expectedResult": {
    "smsCommandExpected": true,
    "expectedSmsCommandCountPerOrder": 1,
    "description": "Delay SMS should be evaluated based on the updated expectedDeliveryTime, not the original one."
  }
}