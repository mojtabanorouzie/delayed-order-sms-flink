{
  "scenarioName": "eta-updated-orders",
  "description": "Orders transition from delayed to on-time via ETA updates. The Flink job should use the latest expectedDeliveryTime.",
  "topic": "Orders",
  "topicType": "compacted",
  "keyField": "orderId",
  "defaultOrderCount": 100,
  "events": [
    {
      "step": 1,
      "delayAfterPreviousEventMs": 0,
      "messageKey": "{{orderId}}",
      "etaOffset": "-30s",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "CREATED",
        "expectedDeliveryTime": "now",
        "createdAt": "now",
        "lastUpdatedAt": "now",
        "eventTime": "now",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 2,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "etaOffset": "-30s",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now",
        "createdAt": "now",
        "lastUpdatedAt": "now+10s",
        "eventTime": "now+10s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 3,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "etaOffset": "+60s",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now",
        "createdAt": "now",
        "lastUpdatedAt": "now+30s",
        "eventTime": "now+30s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          },
          {
            "status": "ETA_UPDATED",
            "at": "now+30s"
          }
        ],
        "schemaVersion": 1
      }
    }
  ],
  "expectedResult": {
    "smsCommandExpected": true,
    "expectedSmsCommandCountPerOrder": 1,
    "description": "SMS should fire when orders are delayed (steps 1-2), then be cancelled when ETA is extended (step 3). Depends on Flink job timer cancellation logic."
  }
}