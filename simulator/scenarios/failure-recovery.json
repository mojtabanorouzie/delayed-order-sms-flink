{
  "scenarioName": "failure-recovery",
  "description": "Orders are produced with future expected delivery time to allow manual Flink failure and recovery testing.",
  "topic": "Orders",
  "topicType": "compacted",
  "keyField": "orderId",
  "defaultOrderCount": 100,
  "executionMode": "pauseable",
  "events": [
    {
      "step": 1,
      "delayAfterPreviousEventMs": 0,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "CREATED",
        "expectedDeliveryTime": "now+180s",
        "createdAt": "now",
        "lastUpdatedAt": "now",
        "eventTime": "now",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 2,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now+180s",
        "createdAt": "now",
        "lastUpdatedAt": "now+10s",
        "eventTime": "now+10s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          }
        ],
        "schemaVersion": 1
      }
    }
  ],
  "failureTestInstructions": [
    "Start Kafka and Flink.",
    "Start the Flink job.",
    "Run this simulator scenario.",
    "Wait until order states are consumed and timers are registered.",
    "Kill or restart the Flink job before expectedDeliveryTime.",
    "Restart the Flink job from checkpoint or savepoint.",
    "Wait until expectedDeliveryTime passes.",
    "Verify exactly one SEND_DELAY_SMS command is emitted per delayed order."
  ],
  "expectedResult": {
    "smsCommandExpected": true,
    "expectedSmsCommandCountPerOrder": 1,
    "description": "After Flink recovery, timers and state should be restored and only one SMS command should be emitted per order."
  }
}