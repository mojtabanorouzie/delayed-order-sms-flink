{
  "scenarioName": "failure-recovery",
  "description": "Orders with delayed ETAs for manual Flink failure and recovery testing.",
  "topic": "Orders",
  "topicType": "compacted",
  "keyField": "orderId",
  "defaultOrderCount": 100,
  "executionMode": "pauseable",
  "events": [
    {
      "step": 1,
      "delayAfterPreviousEventMs": 0,
      "messageKey": "{{orderId}}",
      "etaOffset": "-30s",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "CREATED",
        "expectedDeliveryTime": "now",
        "createdAt": "now",
        "lastUpdatedAt": "now",
        "eventTime": "now",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 2,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "etaOffset": "-30s",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now",
        "createdAt": "now",
        "lastUpdatedAt": "now+10s",
        "eventTime": "now+10s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          }
        ],
        "schemaVersion": 1
      }
    }
  ],
  "failureTestInstructions": [
    "Start Kafka and Flink.",
    "Start the Flink job.",
    "Run this simulator scenario.",
    "SMS commands should be emitted immediately since orders are delayed.",
    "Verify exactly one SEND_DELAY_SMS command is emitted per order."
  ],
  "expectedResult": {
    "smsCommandExpected": true,
    "expectedSmsCommandCountPerOrder": 1,
    "description": "SMS commands should be emitted immediately for all delayed orders."
  }
}