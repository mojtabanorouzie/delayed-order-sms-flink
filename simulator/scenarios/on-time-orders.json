{
  "scenarioName": "on-time-orders",
  "description": "Orders are created and delivered before expected delivery time. No delay SMS should be emitted.",
  "topic": "Orders",
  "topicType": "compacted",
  "keyField": "orderId",
  "defaultOrderCount": 100,
  "events": [
    {
      "step": 1,
      "delayAfterPreviousEventMs": 0,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "CREATED",
        "expectedDeliveryTime": "now+120s",
        "createdAt": "now",
        "lastUpdatedAt": "now",
        "eventTime": "now",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 2,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now+120s",
        "createdAt": "now",
        "lastUpdatedAt": "now+10s",
        "eventTime": "now+10s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 3,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "PICKED_UP",
        "expectedDeliveryTime": "now+120s",
        "createdAt": "now",
        "lastUpdatedAt": "now+30s",
        "eventTime": "now+30s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          },
          {
            "status": "PICKED_UP",
            "at": "now+30s"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 4,
      "delayAfterPreviousEventMs": 1000,
      "messageKey": "{{orderId}}",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "DELIVERED",
        "expectedDeliveryTime": "now+120s",
        "createdAt": "now",
        "lastUpdatedAt": "now+60s",
        "eventTime": "now+60s",
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          },
          {
            "status": "PICKED_UP",
            "at": "now+30s"
          },
          {
            "status": "DELIVERED",
            "at": "now+60s"
          }
        ],
        "schemaVersion": 1
      }
    }
  ],
  "expectedResult": {
    "smsCommandExpected": false,
    "description": "No SEND_DELAY_SMS command should be emitted."
  }
}