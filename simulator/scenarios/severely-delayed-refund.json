{
  "scenarioName": "severely-delayed-refund",
  "description": "Orders whose ETA + 30 minutes has already passed. With refund.delay.minutes=0 the refund fires immediately on event arrival; with the default 30-minute delay a timer is registered.",
  "topic": "Orders",
  "topicType": "compacted",
  "keyField": "orderId",
  "defaultOrderCount": 5,
  "events": [
    {
      "step": 1,
      "delayAfterPreviousEventMs": 0,
      "messageKey": "{{orderId}}",
      "etaOffset": "-35m",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "CREATED",
        "expectedDeliveryTime": "now",
        "createdAt": "now",
        "lastUpdatedAt": "now",
        "eventTime": "now",
        "deliveryFee": 5.00,
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          }
        ],
        "schemaVersion": 1
      }
    },
    {
      "step": 2,
      "delayAfterPreviousEventMs": 500,
      "messageKey": "{{orderId}}",
      "etaOffset": "-35m",
      "value": {
        "orderId": "{{orderId}}",
        "customerId": "{{customerId}}",
        "storeId": "{{storeId}}",
        "status": "ACCEPTED",
        "expectedDeliveryTime": "now",
        "createdAt": "now",
        "lastUpdatedAt": "now+10s",
        "eventTime": "now+10s",
        "deliveryFee": 5.00,
        "stateLogs": [
          {
            "status": "CREATED",
            "at": "now"
          },
          {
            "status": "ACCEPTED",
            "at": "now+10s"
          }
        ],
        "schemaVersion": 1
      }
    }
  ],
  "expectedResult": {
    "refundCommandExpected": true,
    "expectedRefundCommandCountPerOrder": 1,
    "expectedRefundAmountPerOrder": 2.50,
    "description": "One AUTO_REFUND command per severely delayed order. Amount = 50% of $5.00 delivery fee = $2.50. commandId is idempotent: orderId:REFUND_30MIN."
  }
}
